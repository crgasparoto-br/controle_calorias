PUBLIC_APP_URL=https://seu-dominio.com.br
DATABASE_URL=
JWT_SECRET=

# OpenAI backend-only. Never expose OPENAI_* values through VITE_* variables or client-side code.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_IMAGE_MODEL=gpt-image-1

# WhatsApp oficial da solução. Um único número/canal recebe e envia todas as mensagens.
WHATSAPP_PHONE_NUMBER=5511000000000
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=

# Strava OAuth e sincronização de exercícios.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=
STRAVA_APP_REDIRECT_BASE_URL=
# Use um número para limitar chamadas de detalhe por sync, ou "all" para buscar todas as elegíveis.
STRAVA_MAX_ACTIVITY_DETAIL_REQUESTS_PER_SYNC=5