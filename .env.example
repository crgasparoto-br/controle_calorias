# =============================================================================
# CONTROLE CALORIAS - Environment Variables
# =============================================================================
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Secret for signing JWTs (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://calorias_user:calorias_pass@localhost:5432/calorias_db?schema=public

# -----------------------------------------------------------------------------
# Redis (Cache + Queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# WhatsApp Business API (Meta Cloud API)
# -----------------------------------------------------------------------------
# Obtain from: https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_random_string
WHATSAPP_API_VERSION=v19.0

# -----------------------------------------------------------------------------
# OpenAI API
# -----------------------------------------------------------------------------
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL_CHAT=gpt-4o
OPENAI_MODEL_VISION=gpt-4o
OPENAI_MODEL_EMBEDDING=text-embedding-3-small
OPENAI_MODEL_AUDIO=whisper-1

# -----------------------------------------------------------------------------
# Nutrition Database API (optional - USDA FoodData Central)
# -----------------------------------------------------------------------------
# Obtain from: https://fdc.nal.usda.gov/api-guide.html
USDA_API_KEY=your_usda_api_key
USDA_API_BASE_URL=https://api.nal.usda.gov/fdc/v1

# -----------------------------------------------------------------------------
# Sentry (Error Monitoring)
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# -----------------------------------------------------------------------------
# AWS S3 (Media Storage - audio/image files from WhatsApp)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=controle-calorias-media

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Pgvector / Embeddings
# -----------------------------------------------------------------------------
EMBEDDING_DIMENSIONS=1536
