DATABASE_URL=
JWT_SECRET=

VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=

# Main meal flow now runs through the backend OpenAI provider.
# Never expose OPENAI_* values through VITE_* variables or client-side code.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_IMAGE_MODEL=gpt-image-1

# Legacy compatibility flag kept temporarily while non-meal subsystems finish migration.
AI_PROVIDER=openai

# Legacy Forge-backed assistant configuration.
# Keep only while the educational assistant still depends on the legacy provider.
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=

# WhatsApp oficial da solução. Um único número/canal recebe e envia todas as mensagens.
WHATSAPP_PHONE_NUMBER=5511000000000
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=